# Example environment for deploying & operating the EMT contracts.
#
# DO NOT commit real secrets. Copy to `.env` (which is gitignored) and fill in.
# Usage: `set -a && source .env && set +a` (bash) or `export $(cat .env | xargs)`.

# Network selection: testnet | futurenet | mainnet (or a custom RPC URL).
NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Admin (issuer) — secret starting with "S...". Must be funded.
ADMIN_SECRET=
ADMIN_ADDRESS=

# Minter — typically a treasury multisig account.
MINTER_SECRET=
MINTER_ADDRESS=

# Pauser (24/7 ops or guardian EOA).
PAUSER_SECRET=
PAUSER_ADDRESS=

# Blocklister (compliance officer).
BLOCKLISTER_SECRET=
BLOCKLISTER_ADDRESS=

# SEP-0008 hook server key (off-chain compliance service).
HOOK_SERVER_SECRET=
HOOK_SERVER_ADDRESS=

# ── Post-deployment contract IDs (filled in after deploy.sh) ───────────────
EMT_CONTRACT_ID=
HOOK_CONTRACT_ID=
ORACLE_CONTRACT_ID=
