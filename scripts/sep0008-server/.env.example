# SEP-0008 Hook Server — environment template.
# Copy to .env, fill in the values, and `source .env` (or use a process
# manager that injects env vars). All vars are documented in
# docs/sep0008-hook.md §8.

# HTTP listener.
PORT=3000

# Stellar network.
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Hook server signer keypair. The public address must match
# compliance_hook.HookServer on chain.
HOOK_SERVER_SECRET_KEY=S...

# Deployed contract addresses.
EMT_CONTRACT_ID=C...
COMPLIANCE_HOOK_CONTRACT_ID=C...

# API key wallets present in Authorization: Bearer <key>.
API_KEY=replace-me-with-a-long-random-string

# Mock mode: 1 = use in-process mock providers (no external calls).
# Set to 0 in production and fill in the provider URLs / API keys below.
MOCK_MODE=1

# Provider credentials (only required when MOCK_MODE=0).
# KYC_PROVIDER_URL=https://...
# KYC_PROVIDER_API_KEY=...
# SANCTIONS_PROVIDER_URL=https://...
# SANCTIONS_PROVIDER_API_KEY=...
# TRAVEL_RULE_PROVIDER_URL=https://...
# TRAVEL_RULE_PROVIDER_API_KEY=...

LOG_LEVEL=info
RATE_LIMIT_PER_MIN=60
